sdk.dir=C\:/Users/<your-user>/AppData/Local/Android/Sdk

# Android app backend URL.
# Emulator:
# cyl.api.base.url=http://10.0.2.2:8080/
# Physical phone:
# cyl.api.base.url=http://<your-computer-ip>:8080/

# Local LM Studio image reading. Backend must be able to reach this URL.
# If backend runs on the same PC as LM Studio, keep 127.0.0.1.
# If backend runs on Render, 127.0.0.1 will not reach your PC.
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234
# LMSTUDIO_MODEL=qwen/qwen3.5-9b
# LMSTUDIO_VISION_MODEL=qwen/qwen3.5-9b
# LMSTUDIO_API_KEY=
#
# OpenRouter is used when LM Studio is not configured or fails.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Optional OpenRouter image-reading models for AI chat attachments. Must support image input.
# Backend will try these in order until one succeeds.
# OPENROUTER_VISION_MODELS=google/gemma-4-26b-a4b-it:free,google/gemma-3-4b-it:free,google/gemini-2.0-flash-exp:free

# Optional AI web source.
# Android chat settings decide per-message whether web search is used.
# Jina search is attempted first and may work without a key; Exa/Tavily are fallback providers only when keys exist.
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_TIMEOUT_MS=12000
# WEB_SEARCH_CACHE_TTL_SECONDS=900
# JINA_API_KEY=
# EXA_API_KEY=
# TAVILY_API_KEY=

# Backend PostgreSQL persistence.
# Aiven PostgreSQL service URI normally needs sslmode=require.
# Do not commit your real database password.
# DATABASE_URL=postgresql://avnadmin:<password>@<host>:<port>/defaultdb?sslmode=require
# JWT_SECRET=replace-with-a-long-random-secret

# Backend forgot-password email provider.
# Resend requires a verified sender/domain in production.
# RESEND_API_KEY=re_your-key-here
# EMAIL_FROM=ChangeYourLife <noreply@yourdomain.com>
# EMAIL_REPLY_TO=support@yourdomain.com
