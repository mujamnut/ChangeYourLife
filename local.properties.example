sdk.dir=C\:/Users/<your-user>/AppData/Local/Android/Sdk

# Android app backend URL.
# Emulator:
# cyl.api.base.url=http://10.0.2.2:8080/
# Physical phone:
# cyl.api.base.url=http://<your-computer-ip>:8080/

# Backend AI provider. OpenRouter is used first when this key is present.
# Do not commit your real key.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Optional image-reading model for AI chat attachments. Must support image input.
# OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free

# Backend PostgreSQL persistence.
# Aiven PostgreSQL service URI normally needs sslmode=require.
# Do not commit your real database password.
# DATABASE_URL=postgresql://avnadmin:<password>@<host>:<port>/defaultdb?sslmode=require
# JWT_SECRET=replace-with-a-long-random-secret

# Backend forgot-password email provider.
# Resend requires a verified sender/domain in production.
# RESEND_API_KEY=re_your-key-here
# EMAIL_FROM=ChangeYourLife <noreply@yourdomain.com>
# EMAIL_REPLY_TO=support@yourdomain.com
