PORT=8080

# Local development can omit DATABASE_URL.
# When set, the backend runs Flyway migrations and uses PostgreSQL.
DATABASE_URL=postgresql://user:password@localhost:5432/cyl?sslmode=disable
DATABASE_MAX_POOL_SIZE=5

# Replace for any shared/dev deployment.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=cyl-backend
JWT_AUDIENCE=cyl-android
JWT_REALM=cyl
JWT_EXPIRES_IN_MILLIS=604800000

